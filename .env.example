# ── Flask ────────────────────────────────────────────────────────
# Generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string
ADMIN_PASSWORD=your-admin-password

# ── Who receives the daily Excel report ─────────────────────────
PROFESSOR_EMAIL=professor@university.edu
SENDER_NAME=Student Platform

# ── SMTP settings ────────────────────────────────────────────────
# For Gmail: use smtp.gmail.com + App Password (not your real password)
#   Guide: myaccount.google.com > Security > 2-Step Verification > App Passwords
#
# For university/Outlook SMTP, common settings:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender-email@gmail.com
SMTP_PASS=your-app-password

# ── Timezone for the 00:01 AM scheduled email ───────────────────
# Examples: UTC, America/New_York, America/Chicago, America/Los_Angeles,
#           Asia/Shanghai, Europe/London
TIMEZONE=America/New_York

# ── Database (optional) ──────────────────────────────────────────
# DB_PATH=database.db
